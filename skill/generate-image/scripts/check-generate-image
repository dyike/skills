#!/bin/bash
# Check generate-image environment

echo "Checking generate-image environment..."

if [ -z "$GEMINI_API_KEY" ]; then
    echo "❌ GEMINI_API_KEY not set"
    exit 1
else
    echo "✓ GEMINI_API_KEY is set"
fi

if [ -z "$GEMINI_BASE_URL" ]; then
    echo "⚠ GEMINI_BASE_URL not set (will use default: http://127.0.0.1:8045)"
else
    echo "✓ GEMINI_BASE_URL: $GEMINI_BASE_URL"
fi

echo "✓ Environment check passed"
